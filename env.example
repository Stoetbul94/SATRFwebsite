# Frontend Firebase (public) config
NEXT_PUBLIC_FIREBASE_PROJECT_ID=satrf-website

# Server-side Firebase Admin (REQUIRED for registration, approvals, score writes).
# Paste the FULL service-account JSON as a single-line string.
# Get it from: Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"satrf-website", ...}

# Optional fallback admin allowlist (comma-separated emails). Primary admin
# Comma-separated admin emails (server-side fallback if Firestore role is wrong).
# Primary admin detection is Firestore `role: "admin"` or `roles.admin: true`.
ADMIN_EMAILS=techaim10.9@gmail.com

# Sentry Configuration
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Application Configuration
NEXT_PUBLIC_APP_NAME=SATRF
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature Flags
NEXT_PUBLIC_ENABLE_REGISTRATION=true
NEXT_PUBLIC_ENABLE_SCORE_UPLOAD=true
NEXT_PUBLIC_ENABLE_EVENT_REGISTRATION=true 