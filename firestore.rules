rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================================
    // USERS COLLECTION RULES
    // ============================================================================
    // Users can read their own profile and create their own user document during registration
    // Admins can read/write all user documents
    // ============================================================================
    
    function isAdmin() {
      return request.auth != null
        && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.admin == true);
    }

    match /users/{userId} {
      // Users can read their own profile.
      allow read: if request.auth != null && request.auth.uid == userId;

      // Registration is handled server-side via the Admin SDK (which bypasses
      // these rules), so client-side create is intentionally NOT allowed.
      allow create: if false;

      // Users may update their own profile but cannot change role, status,
      // email, or id (privilege-escalation / self-approval protection).
      allow update: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.id == resource.data.id
                   && request.resource.data.email == resource.data.email
                   && request.resource.data.role == resource.data.role
                   && request.resource.data.status == resource.data.status;

      // Admins can read/write all user documents.
      allow read, write: if isAdmin();
    }
    
    // ============================================================================
    // SCORES COLLECTION RULES
    // ============================================================================
    // Users can read all scores (public leaderboard)
    // Users can create their own scores
    // Admins can read/write all scores
    // ============================================================================
    
    match /scores/{scoreId} {
      // Public read access for the leaderboard / rankings.
      allow read: if true;

      // Scores are official results — only admins (or the server Admin SDK)
      // may create, update, or delete them. Members cannot self-insert scores.
      allow write: if isAdmin();
    }
    
    // ============================================================================
    // ADMIN ACTIONS COLLECTION RULES
    // ============================================================================
    // Only admins can read/write admin actions
    // ============================================================================
    
    match /adminActions/{actionId} {
      allow read, write: if isAdmin();
    }
    
    // ============================================================================
    // EVENTS COLLECTION RULES
    // ============================================================================
    // Public read access for events
    // Admins can create/update/delete events
    // ============================================================================
    
    match /events/{eventId} {
      // Public read access
      allow read: if true;

      // Only admins can create/update/delete events
      allow write: if isAdmin();
    }

    // Legacy eventRegistrations — deny client access (use Admin SDK / API routes).
    match /eventRegistrations/{regId} {
      allow read, write: if false;
    }

    // Guest + member event registrations — written only via Next.js API (Admin SDK).
    match /registrations/{regId} {
      allow read, write: if false;
    }
    
    // ============================================================================
    // DEFAULT DENY
    // ============================================================================
    // All other collections are denied by default
    // ============================================================================
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

